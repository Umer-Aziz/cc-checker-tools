# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is intentionally NOT ignored (it's the public template)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AI agent / IDE config — not relevant to the project itself
CLAUDE.md
AGENTS.md
GEMINI.md
.claude/
.cursor/
.aider*
.copilot/

# Design specs and internal docs
/docs/

# OS metadata
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
